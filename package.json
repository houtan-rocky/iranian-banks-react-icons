{
  "name": "@iran-utils/monorepo",
  "private": true,
  "description": "pnpm monorepo for Iranian banks icon packages",
  "scripts": {
    "optimize": "rimraf ./optimized && svgo -q -p 8 -f ./raw -o ./optimized",
    "build:core": "node scripts/build-core.js",
    "build:react": "node scripts/build-react.js",
    "build:vue": "node scripts/build-vue.js",
    "build": "pnpm optimize && pnpm build:core && pnpm build:react && pnpm build:vue",
    "prepare": "pnpm build",
    "docs:dev": "pnpm --filter docs dev",
    "docs:build": "pnpm build && pnpm --filter docs build",
    "release": "pnpm changeset publish"
  },
  "devDependencies": {
    "@babel/core": "catalog:build",
    "@babel/preset-react": "catalog:build",
    "@changesets/cli": "catalog:releases",
    "@svgr/cli": "catalog:build",
    "@svgr/core": "catalog:build",
    "camelcase": "catalog:build",
    "rimraf": "catalog:build",
    "svgo": "catalog:build",
    "terser": "catalog:build"
  }
}
