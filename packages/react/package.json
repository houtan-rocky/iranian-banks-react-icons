{
  "name": "@iran-utils/iranian-banks-react-icons",
  "version": "1.0.2",
  "description": "React SVG icon library for Iranian banks and payment providers — 60+ logos with color and monochrome variants.",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "sideEffects": false,
  "files": ["dist", "index.d.ts"],
  "author": "Houtan Rocky",
  "license": "MIT",
  "keywords": [
    "react", "icons", "svg", "svg-icons", "react-icons", "react-svg",
    "iranian", "persian", "iran", "bank", "bank-icons", "banking",
    "fintech", "payment", "payment-icons", "iranian-bank",
    "melli", "mellat", "saderat", "tejarat", "pasargad", "saman",
    "parsian", "zarrinpal", "idpay", "vandar", "shaparak", "psp"
  ],
  "bugs": { "url": "https://github.com/houtan-rocky/iranian-banks-react-icons/issues" },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/houtan-rocky/iranian-banks-react-icons.git",
    "directory": "packages/react"
  },
  "homepage": "https://houtan-rocky.github.io/iranian-banks-react-icons/",
  "dependencies": {
    "@iran-utils/iranian-banks-icons-core": "workspace:*"
  },
  "peerDependencies": {
    "react": "^16.13.1 || ^17.0.1 || ^18.0.0 || ^19.2.0"
  }
}
